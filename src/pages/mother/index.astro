---
import Layout from "../../layouts/Layout.astro";
import madres from "../../mock/madres.json";
---

<Layout title="Selecciona una Madre">
  <div class="min-h-screen bg-linear-to-b from-pink-50 to-purple-50 py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-center mb-4 bg-linear-to-r from-pink-600 to-rose-600 bg-clip-text text-transparent">
        Elige una Madre
      </h1>
      <p class="text-center text-gray-600 mb-12">Selecciona a una de nuestras madres especiales</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {madres.map(madre => (
          <a 
            href={`/mother/${madre.slug}`}
            class="group relative overflow-hidden rounded-xl bg-white shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1"
          >
            <div class="p-6">
              <div class="text-5xl mb-4">{madre.emoji}</div>
              <h2 class="text-2xl font-bold text-gray-800 mb-2 group-hover:text-pink-600 transition">
                {madre.nombre}
              </h2>
              <p class="text-pink-600 font-semibold mb-3">{madre.titulo}</p>
              <p class="text-gray-600">{madre.descripcion}</p>
            </div>
            <div class="absolute inset-0 bg-linear-to-r from-pink-500/0 to-rose-500/0 group-hover:from-pink-500/10 group-hover:to-rose-500/10 transition pointer-events-none"></div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>